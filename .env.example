# ================================================================
# Aarohan++ Environment Variables
# Copy this to .env and fill in your values
# ================================================================

# ─── Application ───────────────────────────────────────────────
APP_NAME="Aarohan++ NHCX Compliance Intelligence Platform"
APP_VERSION=0.1.0
DEBUG=true

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aarohan:aarohan_dev@localhost:5432/aarohan_db

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── FHIR Server ──────────────────────────────────────────────
FHIR_SERVER_URL=http://localhost:8080/fhir

# ─── NRCeS Snowstorm ──────────────────────────────────────────
SNOWSTORM_BASE_URL=https://snowstorm.nrces.in/fhir
SNOWSTORM_API_KEY=

# ─── NHCX Network ─────────────────────────────────────────────
NHCX_BASE_URL=https://staging-hcx.swasth.app/api/v0.8
NHCX_PARTICIPANT_CODE=
NHCX_AUTH_TOKEN=
NHCX_ENCRYPTION_CERT_PATH=
NHCX_SIGNING_KEY_PATH=

# ─── OpenHCX Network ──────────────────────────────────────────
OPENHCX_BASE_URL=https://api.openhcx.io/v0.9

# ─── Dummy Payer ──────────────────────────────────────────────
DUMMY_PAYER_URL=http://localhost:8090/payer
USE_MOCK_PAYER=true

# ─── NLP ──────────────────────────────────────────────────────
SPACY_MODEL=en_core_sci_lg
NLP_CONFIDENCE_THRESHOLD=0.75
